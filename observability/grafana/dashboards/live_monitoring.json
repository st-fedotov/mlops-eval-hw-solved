{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Refusal rate by input_category (5m rolling)",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (input_category) (rate(chat_requests_total{refused=\"true\"}[5m])) / sum by (input_category) (rate(chat_requests_total[5m]))",
          "legendFormat": "{{input_category}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8},
      "id": 2,
      "title": "DIVERGENCE: cheap refusal-rate vs judge leakage-rate",
      "description": "Cheap refusal-rate is exact-match on the canned refusal string (100% of traffic, 5m window). Judge leakage-rate is the deep judge on sampled traffic (1h window). When they diverge — cheap says 'refused' but judge says 'leaked' — you've shipped a regression.",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(chat_requests_total{refused=\"true\"}[5m])) / sum(rate(chat_requests_total[5m]))",
          "legendFormat": "cheap refusal-rate (5m, 100% traffic)"
        },
        {
          "refId": "B",
          "expr": "sum(rate(judge_evaluations_total{verdict=\"leaked\"}[1h])) / sum(rate(judge_evaluations_total[1h]))",
          "legendFormat": "judge leakage-rate (1h, sampled)"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8},
      "id": 3,
      "title": "Request rate by config",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (config_id) (rate(chat_requests_total[5m]))",
          "legendFormat": "{{config_id}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 17},
      "id": 4,
      "title": "Request latency (p50 / p95 / p99) by config",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, config_id) (rate(chat_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{config_id}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, config_id) (rate(chat_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{config_id}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, config_id) (rate(chat_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{config_id}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 17},
      "id": 5,
      "title": "Burn rate ($/hour) by model",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(chat_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 26},
      "id": 6,
      "title": "In-flight requests",
      "type": "stat",
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"refId": "A", "expr": "in_flight_requests"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 26},
      "id": 7,
      "title": "Deep judge queue depth",
      "description": "If this grows monotonically, the async judge worker is falling behind sampled traffic.",
      "type": "stat",
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}, "overrides": []},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"refId": "A", "expr": "deep_judge_queue_depth"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 26},
      "id": 8,
      "title": "Judge sample rate",
      "type": "stat",
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"refId": "A", "expr": "judge_sample_rate"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 26},
      "id": 9,
      "title": "Current deployment",
      "description": "assistant_info — labels describe what's deployed.",
      "type": "table",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true},
      "transformations": [
        {"id": "labelsToFields", "options": {"valueLabel": ""}},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true}}}
      ],
      "targets": [{"refId": "A", "expr": "assistant_info", "format": "table", "instant": true}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "id": 10,
      "title": "Judge verdicts (1h rolling)",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (rate(judge_evaluations_total[1h]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "id": 11,
      "title": "LLM API error rate by type",
      "type": "timeseries",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"showLegend": true, "placement": "bottom", "displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (rate(llm_api_errors_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ],
  "refresh": "10s",
