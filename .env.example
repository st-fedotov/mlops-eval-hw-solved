# Nebius Token Factory (OpenAI-compatible endpoint)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# MLflow (matches docker-compose)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=travel-assistant

# Assistant service
ASSISTANT_CONFIG=v1
CONFIGS_DIR=configs
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8000

# MLflow Model Registry — production deployment shape.
# In dev mode, leave ASSISTANT_MODEL_ALIAS unset; the service loads from ASSISTANT_CONFIG.
# In production, set ASSISTANT_MODEL_ALIAS to a Registry alias (e.g., "production").
# MLflow lowercases alias names on save, so use the lowercase form here.
MLFLOW_REGISTERED_MODEL_NAME=travel-assistant
# ASSISTANT_MODEL_ALIAS=production

# Optional: gates POST /admin/reload. When set, requests must carry an
# `X-Admin-Token: <value>` header. Unset (dev default) = endpoint open.
# In production set to a random secret. PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
# ADMIN_TOKEN=

# Judge — orthogonal to variants; one global judge per session.
JUDGE_MODEL=meta-llama/Llama-3.3-70B-Instruct
JUDGE_TEMPERATURE=0.0

# Sampled deep-judge monitoring
JUDGE_SAMPLE_RATE=0.05
JUDGE_QUEUE_MAXSIZE=1000

# MinIO (MLflow artifact store; defaults match docker-compose)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
