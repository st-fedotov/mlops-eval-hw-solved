# Nebius Token Factory (OpenAI-compatible endpoint)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# MLflow (matches docker-compose)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=travel-assistant

# Assistant service
VARIANT=v1
VARIANTS_FILE=variants.yaml
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8000

# Judge — orthogonal to variants; one global judge per session.
JUDGE_MODEL=meta-llama/Llama-3.3-70B-Instruct
JUDGE_TEMPERATURE=0.0

# Sampled deep-judge monitoring
JUDGE_SAMPLE_RATE=0.05
JUDGE_QUEUE_MAXSIZE=1000

# MinIO (MLflow artifact store; defaults match docker-compose)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
